# Debater App — Environment Variables
#
# Copy this file to .env and fill in your API keys
#

# Option 1: OpenRouter (Recommended)
# Get your API key from: https://openrouter.ai/keys
# OpenRouter supports Kimi, Claude, GPT, Gemini, and many others
OPENROUTER_API_KEY=

# Option 2: Kimi/Moonshot AI (Direct)
# Get your API key from: https://platform.moonshot.cn/
# Use this if you want to call Kimi directly without OpenRouter
KIMI_API_KEY=

# LLM routing: if BOTH `OPENROUTER_API_KEY` and `KIMI_API_KEY` are set, the server uses
# OpenRouter for all models (including `moonshotai/kimi-*`). Direct Moonshot is used only
# when `OPENROUTER_API_KEY` is unset and `KIMI_API_KEY` is set.

# Optional: log raw OpenRouter/Moonshot chat completion `delta` keys + reasoning extraction per SSE line (noisy).
# DEBUG_DEBATE_SSE=1

# Server Configuration (defaults are uncommon ports to avoid clashes with other tools)
PORT=38471

# Vite dev server port (`npm run dev`). Must match what you open in the browser when using the proxy.
VITE_DEV_PORT=52817

# Optional: override OpenRouter HTTP-Referer (defaults to http://localhost:${VITE_DEV_PORT})
# OPENROUTER_HTTP_REFERER=http://localhost:52817

# Frontend — API origin for fetch + EventSource (optional).
# For local dev: leave empty so the browser calls /api on the Vite port; Vite proxies to PORT (see vite.config.ts).
# Set only for split-origin deploys, e.g.: VITE_API_URL=https://api.example.com
VITE_API_URL=